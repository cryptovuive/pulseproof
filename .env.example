# mainnet or devnet — all TxLINE and Solana values must use the same network.
TXLINE_NETWORK=devnet
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
# Set this only after receiving written post-hackathon data permission from TxODDS.
TXLINE_WRITTEN_DATA_LICENSE_EXTENDED=false

# Explicitly enable the labelled historical replay for local demos/video capture.
DEMO_REPLAY_ENABLED=true

# Base58-encoded 64-byte nacl secret key for server attestations.
# Never expose this in NEXT_PUBLIC_* variables or commit it.
ATTESTOR_SECRET_KEY=

NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PULSEPROOF_PROGRAM_ID=74cvsTMZpcgrzVT7ufSjtjy8gqU2m1q3jy3n1UGxRMkn
