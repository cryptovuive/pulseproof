    "contract:alias:devnet": "tsx scripts/devnet-alias-e2e.ts",
    "contract:e2e:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-localnet-e2e.ps1",
    "wallet:create": "tsx scripts/create-phantom-test-wallet.ts",
    "wallet:test": "tsx scripts/test-phantom-wallet.ts",
    "wallet:e2e:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-wallet-e2e.ps1",
    "attestor:create": "tsx scripts/create-attestor-secret.ts",
    "txline:verify": "tsx scripts/verify-txline-stream.ts",
