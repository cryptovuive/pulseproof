{
  "name": "pulseproof",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "contract:test": "vitest run tests/contract-model.test.ts",
    "contract:init": "tsx scripts/initialize-config.ts",
    "contract:e2e": "tsx scripts/localnet-e2e.ts",
    "contract:e2e:devnet": "tsx scripts/devnet-e2e.ts",
    "contract:retired:devnet": "tsx scripts/verify-retired-reward-devnet.ts",
