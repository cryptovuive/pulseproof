    "tweetnacl": "1.0.3",
    "ws": "8.21.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.2",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "tsx": "4.23.0",
    "typescript": "5.7.2",
    "vitest": "4.1.10"
